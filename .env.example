
# ── Mode démo ──────────────────────────────────────────────────────────────────
# MOCK_MODE=true injecte une session admin factice (readSession) : toutes les pages
# reader/editor/admin deviennent accessibles sans backend KSM ni Redis. Les widgets
# qui chargent des données réelles via KSM afficheront un état vide/erreur — ce
# mode sert à parcourir/valider l'UI, pas à simuler des données métier.
MOCK_MODE=false

# ── KSM (backend) ──────────────────────────────────────────────────────────────
# [REQUIS EN PROD] URL de base du kernel KSM. Pas de fallback utilisable en prod.
KSM_BASE_URL=http://localhost:8080

# Identifiant client envoyé dans X-Client-Id (a un défaut de code, mais à définir
# explicitement en prod pour matcher l'enregistrement côté KSM).
KSM_CLIENT_ID=yownews-frontend
# [REQUIS EN PROD] Clé API envoyée dans X-Api-Key. Vide par défaut = aucun appel KSM ne passera.
KSM_API_KEY=

# Code de l'organisation plateforme YowNews côté KSM (défaut : YOWNEWS).
KSM_PLATFORM_ORG_CODE=YOWNEWS

# Email du compte admin plateforme, utilisé côté serveur pour poser le rôle
# Lecteur aux nouveaux inscrits (défaut : admin@yownews.com). Jamais exposé au client.
KSM_PLATFORM_ADMIN_EMAIL=admin@yownews.com

# [REQUIS EN PROD] Mot de passe du compte admin plateforme (provisionnement du rôle
# Lecteur à l'inscription). L'email a un défaut ; le mot de passe non — vide = échec silencieux.
KSM_PLATFORM_ADMIN_PASSWORD=

# ── Sessions ───────────────────────────────────────────────────────────────────
# [REQUIS EN PROD] Secret de chiffrement des sessions (≥ 32 caractères aléatoires).
# Sans valeur, le code retombe sur un secret par défaut non sécurisé (voir src/env.ts).
SESSION_SECRET=

# Nom du cookie de session déposé côté navigateur (défaut : yownews_session).
SESSION_COOKIE_NAME=yownews_session

# Durée de vie de la session en secondes (défaut : 3600 = 1h).
SESSION_TTL_SECONDS=3600

# ── Redis (stockage des sessions) ──────────────────────────────────────────────
# [REQUIS EN PROD] Hôte du serveur Redis. localhost n'existe pas en environnement déployé.
REDIS_HOST=localhost
# En dev local le conteneur Redis est exposé sur 6380 (défaut du code : 6379).
REDIS_PORT=6380
# [REQUIS EN PROD SI Redis est protégé] Mot de passe Redis. Vide = pas d'auth envoyée.
REDIS_PASSWORD=

# ── Divers ─────────────────────────────────────────────────────────────────────
# Environnement d'exécution Node (development | production | test). Généralement
# fixé par la plateforme d'hébergement plutôt que par ce fichier.
NODE_ENV=development

# [REQUIS EN PROD — mettre à false] Mode démo : contourne KSM/Redis avec une session
# admin factice. Ne doit JAMAIS être true en production.
NEXT_PUBLIC_MOCK_MODE=false

# [REQUIS EN PROD SI KSM_PLATFORM_ORG_CODE ≠ défaut du code] Équivalent exposé au
# client de KSM_PLATFORM_ORG_CODE, utilisé pour détecter l'org plateforme côté UI
# (src/app/[locale]/editor/my-org/page.tsx, org-publisher/page.tsx).
NEXT_PUBLIC_KSM_PLATFORM_ORG_CODE=YOWNEWS
