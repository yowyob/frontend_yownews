
# ── KSM (backend) ──────────────────────────────────────────────────────────────
# URL de base du kernel KSM.
KSM_BASE_URL=http://localhost:8080

# Identifiant client + clé API envoyés dans X-Client-Id / X-Api-Key.
KSM_CLIENT_ID=yownews-frontend
KSM_API_KEY=

# Mot de passe du compte admin plateforme (provisionnement du rôle Lecteur à
# l'inscription). L'email a un défaut (admin@yownews.com) ; le mot de passe non.
KSM_PLATFORM_ADMIN_PASSWORD=

# ── Sessions ───────────────────────────────────────────────────────────────────
# Secret de chiffrement des sessions (≥ 32 caractères aléatoires).
SESSION_SECRET=

# ── Redis (stockage des sessions) ──────────────────────────────────────────────
REDIS_HOST=localhost
# En dev local le conteneur Redis est exposé sur 6380 (défaut du code : 6379).
REDIS_PORT=6380
